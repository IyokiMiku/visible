        {
          "questionId": "3646919355654144",
          "courseId": 10002,
          "typeId": "1000202",
          "topTypeId": "1000202",
          "typeFeatureIds": [],
          "paperId": "3642311600308224",
          "source": "《电工技术基础与技能》综合练习（五）45分钟专题训练（原卷版+)",
          "year": 2024,
          "difficulty": 0.65,
          "stem": "<div class=\"qml-stem\"><p style=\"text-align: left;\"><span style=\"font-family: 宋体;\">一根导线的电阻值为</span><span style=\"font-family: 'Times New Roman';\">10</span><span style=\"font-family: 宋体;\">Ω，若将其均匀拉长一倍或缩短一半时，则拉长一倍时电阻为</span><span style=\"font-family: 'Times New Roman';\">20</span><span style=\"font-family: 宋体;\">Ω，缩短一半时电阻为</span><span style=\"font-family: 'Times New Roman';\">5</span><span style=\"font-family: 宋体;\">Ω。</span><span class=\"qml-bk\" index=\"1\" size=\"5\" type=\"bracket\">（　　　　　）</span></p></div>",
          "answer": "<div class=\"qml-answer\"><span class=\"qml-an-sq\"><span class=\"qml-an\" judge=\"0\"><span style=\"font-family: 宋体;\">错误</span></span></span></div>",
          "explanation": "<div class=\"qml-explanation\"><div class=\"qml-seg\" seg-name=\"详解\">【详解】<p style=\"text-align: left;\"><span style=\"font-family: 宋体;\">对于一根导线，在均匀拉长时，体积不变。设原来导线的长度为</span><span style=\"font-family: 'Times New Roman';\">L</span><span style=\"font-family: 宋体;\">，横截面积为</span><span style=\"font-family: 'Times New Roman';\">S</span><span style=\"font-family: 宋体;\">，则体积</span><span style=\"font-family: 'Times New Roman';\">V=LS</span><span style=\"font-family: 宋体;\">。</span></p><p style=\"text-align:justify;word-break:break-word;\"><span style=\"font-family: 宋体;\">拉长一倍后，长度变为</span><span style=\"font-family: 'Times New Roman';\">2L</span><span style=\"font-family: 宋体;\">，由于体积不变，此时横截面积变为</span><span style=\"font-family: 'Times New Roman';\">S/2</span><span style=\"font-family: 宋体;\">。根据电阻公式</span><math latex=\"$\\mathrm{R}=\\rho \\frac{\\mathrm{L}}{\\mathrm{S}}$\"><mrow><mtext>R</mtext><mo>=</mo><mi>ρ</mi><mfrac><mtext>L</mtext><mtext>S</mtext></mfrac></mrow></math><span style=\"font-family: 'Times New Roman';\"> </span><span style=\"font-family: 宋体;\">，拉长一倍后电阻</span><math latex=\"$\\mathrm{R}=\\rho \\frac{2\\mathrm{L}}{\\mathrm{S}/2}=4\\rho \\frac{\\mathrm{L}}{\\mathrm{S}}$\"><mrow><mtext>R</mtext><mo>=</mo><mi>ρ</mi><mfrac><mrow><mtext>2L</mtext></mrow><mrow><mtext>S/2</mtext></mrow></mfrac><mo>=</mo><mn>4</mn><mi>ρ</mi><mfrac><mtext>L</mtext><mtext>S</mtext></mfrac></mrow></math><span style=\"font-family: 宋体;\">。故电阻应变为</span><span style=\"font-family: 'Times New Roman';\">40</span><span style=\"font-family: 宋体;\">Ω。分析缩短一半的情况：缩短一半后，长度变为</span><span style=\"font-family: 'Times New Roman';\">L/2</span><span style=\"font-family: 宋体;\">，体积</span><span style=\"font-family: 'Times New Roman';\">V</span><span style=\"font-family: 宋体;\">不变，横截面积变为</span><span style=\"font-family: 'Times New Roman';\">2S</span><span style=\"font-family: 宋体;\">。缩短一半后电阻</span><math latex=\"$\\mathrm{R}=\\rho \\frac{\\mathrm{L}/2}{2\\mathrm{S}}=\\frac{1}{4}\\rho \\frac{\\mathrm{L}}{\\mathrm{S}}$\"><mrow><mtext>R</mtext><mo>=</mo><mi>ρ</mi><mfrac><mrow><mtext>L/2</mtext></mrow><mrow><mtext>2S</mtext></mrow></mfrac><mo>=</mo><mfrac><mn>1</mn><mn>4</mn></mfrac><mi>ρ</mi><mfrac><mtext>L</mtext><mtext>S</mtext></mfrac></mrow></math><span style=\"font-family: 宋体;\">，故电阻变为</span><span style=\"font-family: 'Times New Roman';\">2.5</span><span style=\"font-family: 宋体;\">Ω。故表述错误。</span></p></div></div>",
