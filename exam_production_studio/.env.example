# 出卷集成工作台 — 环境变量样例
# 复制为 .env 后填入真实值；.env 不要提交到版本库。
# 源码中不留明文密钥，统一由 backend/config.py 从 .env + settings 表加载。

# ---------- LLM 凭据 ----------
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ---------- 学科网凭据 ----------
XKW_COOKIE=
XKW_APP_KEY=
XKW_SIGN=

# ---------- 视觉模型（预留，暂不启用） ----------
VISION_API_KEY=
VISION_BASE_URL=
VISION_MODEL=

# ---------- 数据库 ----------
# SQLite 路径，默认 data/studio.db
STUDIO_DB=data/studio.db
